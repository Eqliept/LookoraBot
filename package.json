{
  "type": "module",
  "dependencies": {
    "@grammyjs/i18n": "^1.1.2",
    "@prisma/client": "^6.19.2",
    "dotenv": "^17.2.3",
    "grammy": "^1.39.3",
    "prisma": "^6.19.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "typescript": "^5.9.3",
    "cpx": "^1.5.0"
  },
  "scripts": {
    "build": "tsc && npm run copy-images && npm run copy-languages",
    "copy-images": "cpx \"src/images/**/*\" dist/images",
    "copy-languages": "cpx \"src/languages/**/*\" dist/languages",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  }
}